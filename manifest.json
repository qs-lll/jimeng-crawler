{
  "manifest_version": 3,
  "name": "jimeng内容采集",
  "version": "1.0",
  "description": "点开详细信息后，获取即梦图片信息",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["*://jimeng.jianying.com/*", "*://discord.com/*", "*://*.discord.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://jimeng.jianying.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
